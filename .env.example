# Database (Railway provisions this automatically when you add a Postgres service)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"
# Optional: only set if the public webhook URL differs from the request host
# (used for Twilio signature verification). e.g. "https://your-app.up.railway.app"
TWILIO_WEBHOOK_BASE_URL=""

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Google Calendar
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost"
GOOGLE_REFRESH_TOKEN=""
GOOGLE_CALENDAR_ID=""

# Internal cron endpoint (Railway cron calls /api/internal/process-scheduled-actions with this header)
INTERNAL_CRON_SECRET="change-me"

# Dashboard login (single shared internal account, per spec section 22)
ADMIN_USERNAME="admin"
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=""

# Session signing secret — generate with: openssl rand -base64 32
SESSION_SECRET=""

# App version tag, stored on every outbound message (spec section 23)
APP_VERSION="1.0.0"
